# ============================================================================
#  Environment template — copy to `.env` for local use, and set the same keys
#  as (1) Netlify environment variables and (2) GitHub Actions repo secrets.
#  NEVER commit the real .env (it is git-ignored). Values below are placeholders.
# ============================================================================

# ---- Netlify environment variables (power the live serverless functions) ----
#   Set in: Netlify → Site settings → Environment variables
ANTHROPIC_API_KEY=sk-ant-...        # chat (ask), research, live look-ups
POLYGON_KEY=...                     # quotes, option-check, exec-cost, leaderboard
FINNHUB_KEY=...                     # quote fallback
ASK_MODEL=claude-opus-4-8           # optional; model used by the chat functions

# ---- GitHub Actions repo secrets (power the scheduled daily/weekly refresh) ----
#   Set in: GitHub → repo → Settings → Secrets and variables → Actions
#   Needs: ANTHROPIC_API_KEY, POLYGON_KEY (above) PLUS:
FRED_API_KEY=...                    # live macro inputs (CAPE, real rates, VIX, HY, etc.)

# ---- Local-only browser fallback (NOT for production) ----
#   site/keys.js (git-ignored) exposes window.ANTHROPIC_KEY / POLYGON_KEY /
#   FINNHUB_KEY for direct browser calls during local dev. On the deployed site
#   keys.js is absent, so the client automatically routes through the Netlify
#   functions above — keys stay server-side. Do not ship keys.js publicly.
